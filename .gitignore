__pycache__/
*.pyc
*.pyo
.env
*.egg-info/
dist/
build/
*.db
*.sqlite3
.idea/
.vscode/
*.swp
*.swo
*~
# Phase 9.5 — auto-generated Fernet master key for settings encryption.
# NEVER commit this file; losing it means losing access to every
# encrypted settings value (API keys etc.). Back it up separately.
.slowbooks-master.key

# Session signing key (auto-generated on first boot). NEVER commit.
.slowbooks-session.key

# Pytest / coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.ruff_cache/

# User-uploaded attachments / logos — runtime data, not source
app/static/uploads/

# pg_dump output — the backups/ dir itself stays tracked (via .gitkeep)
# so the backup feature has somewhere to drop files on a fresh install,
# but the dumps themselves are runtime data.
backups/*
!backups/.gitkeep

# OS-level cruft
.DS_Store
Thumbs.db

# Build artifacts from pip installs done in this directory
*.egg


# Coverage XML artifact from pytest --cov (CI writes its own)
coverage.xml
