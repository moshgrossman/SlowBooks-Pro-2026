# ============================================================================
# Slowbooks Pro 2026 — Environment Variables
# Copy to .env and customize: cp .env.example .env
# ============================================================================

# ============================================================================
# CORE APPLICATION
# ============================================================================

APP_HOST=0.0.0.0
APP_PORT=3001

# Set APP_DEBUG=true ONLY for local development. In production it disables
# the fail-hard startup checks that protect against accidentally shipping
# without TLS, without an encryption secret, etc.
APP_DEBUG=false

# ============================================================================
# DATABASE
# ============================================================================

# Native Linux install:
# DATABASE_URL=postgresql://bookkeeper:bookkeeper@localhost:5432/bookkeeper?sslmode=require

# Production MUST include ?sslmode=require (or ?sslmode=verify-full with a
# pinned CA). Startup will fail hard otherwise when APP_DEBUG=false.

# Docker install — these are picked up by docker-compose.yml:
POSTGRES_USER=bookkeeper
POSTGRES_PASSWORD=bookkeeper
POSTGRES_DB=bookkeeper

# ============================================================================
# TRANSPORT SECURITY
# ============================================================================

# Default true in production (APP_DEBUG=false). Enables:
#   - HTTPSRedirectMiddleware (308 plain HTTP -> HTTPS at the app layer)
#   - Strict-Transport-Security header (HSTS)
#   - `Secure` flag on the session cookie
# Set to false only when something in front of the app already terminates
# TLS and you don't want the app's own redirect.
FORCE_HTTPS=true

# HSTS max-age in seconds. Default 63072000 = 2 years (the preload-list
# minimum). Browsers cache the directive for this long.
HSTS_MAX_AGE=63072000

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Cookie-signing secret. If unset, the app auto-generates one to
# .slowbooks-session.key on first boot. For production, set this yourself
# so re-deploys don't invalidate every active session:
#   openssl rand -hex 32
# SESSION_SECRET_KEY=

# Idle session cap. Sliding window — every authenticated request rolls
# the clock forward. 0 disables the idle check. Default 14400s = 4 hours.
SESSION_IDLE_TIMEOUT_SECONDS=14400

# Rate limiting (login + portal endpoints). Set to 0 only in test
# environments or load-testing.
RATE_LIMIT_ENABLED=1

# Browser origins allowed to call the API. Leave unset to default to
# loopback only. For a separate UI host:
#   CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGINS=

# ============================================================================
# AT-REST ENCRYPTION
# ============================================================================

# Symmetric key used to encrypt employee bank routing/account numbers and
# other PII at rest (Fernet, PBKDF2-SHA256 480k iterations).
#
# Generate a strong value:
#   openssl rand -base64 32
#
# Startup will refuse to boot in production with the dev default.
PAYROLL_ENCRYPTION_SECRET=

# OPTIONAL: previous secret, used during key rotation. The app decrypts
# legacy ciphertext with PREV when current fails. Rotate via:
#   1. Move the current value into PAYROLL_ENCRYPTION_SECRET_PREV
#   2. Set a new PAYROLL_ENCRYPTION_SECRET
#   3. Bounce the app
#   4. Run the rewrap migration (see docs/security-hardening.md)
#   5. Drop PAYROLL_ENCRYPTION_SECRET_PREV
# PAYROLL_ENCRYPTION_SECRET_PREV=

# ============================================================================
# COMPANY INFO (optional — also settable from the UI after first login)
# ============================================================================

COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
DEFAULT_TERMS=Net 30
DEFAULT_TAX_RATE=0.0

# ============================================================================
# EMPLOYER PAYROLL IDENTIFIERS (used by tax forms)
# ============================================================================

# Employer EIN (XX-XXXXXXX). Required for W-2/W-3/940/941 generation.
EMPLOYER_EIN=

# Two-letter state code for the employer's primary location. Drives the
# default state-tax engine.
EMPLOYER_STATE=WA

# State unemployment tax (SUTA) experience rate as a decimal. WA average
# is around 1.2% — verify with your state agency.
SUTA_RATE=0.012
