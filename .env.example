# ============================================================================
# Slowbooks Pro 2026 — Environment Variables
# Copy to .env and customize: cp .env.example .env
# ============================================================================

# --- Native Linux Install ---
# DATABASE_URL=postgresql://bookkeeper:bookkeeper@localhost:5432/bookkeeper

# --- Docker Install ---
# These are used by docker-compose.yml (no need to change for default setup)
POSTGRES_USER=bookkeeper
POSTGRES_PASSWORD=bookkeeper
POSTGRES_DB=bookkeeper

# Application
APP_HOST=0.0.0.0
APP_PORT=3001
APP_DEBUG=false
# Comma-separated list of browser origins allowed to call the API. Leave
# unset to default to http://localhost:APP_PORT and http://127.0.0.1:APP_PORT.
# Example for a separate UI host: CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGINS=

# Session secret (auto-generated to .slowbooks-session.key if not set).
# For production, set this to a strong random value:
#   openssl rand -hex 32
# SESSION_SECRET_KEY=

# Company Info (can also be set in Settings UI after startup)
COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
DEFAULT_TERMS=Net 30
DEFAULT_TAX_RATE=0.0
